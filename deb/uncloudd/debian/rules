#!/usr/bin/make -f

SOURCE_VERSION  := $(shell dpkg-parsechangelog --show-field version)
VERSION   := 0.19.0-nightly
# TODO(miek): defaults to amd64
DOWNLOAD        := uncloudd_linux_amd64.tar.gz
SOURCE          := https://github.com/miekg/uncloudplus/releases/download/nightly/$(DOWNLOAD)
BINARY          := uncloudd

%:
	dh $@ --with sysuser

override_dh_auto_configure:
	dh_clean
	if [ ! -f $(DOWNLOAD) ]; then curl -L $(SOURCE) > $(DOWNLOAD); fi
	tar xf $(DOWNLOAD) && chmod 755 $(BINARY)

override_dh_strip:

override_dh_auto_clean:
	rm -rf debian/$(BINARY)/usr/bin

override_dh_installsystemd:
	dh_installsystemd --no-start --restart-after-upgrade --name=uncloud

override_dh_auto_install:
	mkdir -p debian/$(BINARY)/usr/bin
	cp $(BINARY) debian/$(BINARY)/usr/bin
	mkdir -p debian/$(BINARY)/etc/docker
	cp debian/docker-daemon.json debian/$(BINARY)/etc/docker/daemon.json
