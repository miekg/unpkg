#!/usr/bin/make -f

# TODO(miek): defaults to amd64
LOCAL           := ""  # if not empty, contains the path where to copy the binary from.
#LOCAL           := ~/src/github.com/superfly/corrosion/corrosion
SOURCE_VERSION  := $(shell dpkg-parsechangelog --show-field version)
DOWNLOAD        := corrosion-x86_64-unknown-linux-gnu.tar.gz
SOURCE          := https://github.com/psviderski/corrosion/releases/download/v${SOURCE_VERSION}/${DOWNLOAD}
#SOURCE          := https://github.com/superfly/corrosion/releases/download/v${SOURCE_VERSION}/${DOWNLOAD}
BINARY          := uncloud-corrosion

%:
	dh $@ --with sysuser

override_dh_auto_configure:
	dh_clean
	if [ -n $(LOCAL) ]; then cp $(LOCAL) $(BINARY); fi
	if [ ! -f $(DOWNLOAD) ]; then curl -L $(SOURCE) > $(DOWNLOAD); \
		tar xf $(DOWNLOAD) && mv corrosion $(BINARY) && chmod 755 $(BINARY); fi

override_dh_strip:

override_dh_auto_clean:
	rm -rf debian/$(BINARY)/usr/bin

override_dh_installsystemd:
	dh_installsystemd --no-start --restart-after-upgrade --name=uncloud-corrosion

override_dh_auto_install:
	mkdir -p debian/$(BINARY)/usr/bin
	cp $(BINARY) debian/$(BINARY)/usr/bin
